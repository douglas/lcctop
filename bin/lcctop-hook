#!/usr/bin/env ruby
# frozen_string_literal: true

# lcctop-hook: Claude Code hook handler for lcctop session tracking.
#
# Called by Claude Code hooks via the cctop plugin.
# Reads hook event JSON from stdin and updates session files in ~/.cctop/sessions/.
#
# Usage: lcctop-hook <HOOK_NAME>

$LOAD_PATH.unshift(File.join(__dir__, "..", "lib"))
require "lcctop"

VERSION = "0.1.0"

def print_help
  puts "lcctop-hook #{VERSION}"
  puts "Claude Code hook handler for lcctop session tracking.\n\n"
  puts "This script is called by Claude Code hooks via the cctop plugin."
  puts "It reads hook event JSON from stdin and updates session files"
  puts "in ~/.cctop/sessions/.\n\n"
  puts "USAGE:"
  puts "    lcctop-hook <HOOK_NAME>\n\n"
  puts "HOOK NAMES:"
  puts "    SessionStart, UserPromptSubmit, PreToolUse, PostToolUse,"
  puts "    Stop, Notification, PermissionRequest, PreCompact, SessionEnd\n\n"
  puts "OPTIONS:"
  puts "    -h, --help       Print this help message"
  puts "    -V, --version    Print version"
end

args = ARGV.to_a

if args.empty?
  Lcctop::Logger.log_error("lcctop-hook: missing hook name argument")
  exit 0
end

case args[0]
when "--version", "-V"
  puts "lcctop-hook #{VERSION}"
  exit 0
when "--help", "-h"
  print_help
  exit 0
end

hook_name = args[0]

begin
  json = $stdin.read
rescue => e
  Lcctop::Logger.log_error("#{hook_name}: failed to read stdin: #{e.message}")
  exit 0
end

begin
  input = Lcctop::HookInput.parse(json)
rescue ArgumentError => e
  Lcctop::Logger.log_error("#{hook_name}: failed to parse JSON: #{e.message}")
  exit 0
end

begin
  Lcctop::HookHandler.handle(hook_name, input)
rescue => e
  Lcctop::Logger.log_error("#{hook_name}: #{e.message}\n#{e.backtrace.first(3).join("\n")}")
  exit 0
end
