#!/usr/bin/env ruby
# frozen_string_literal: true
# lcctop-pick: Beautiful TUI session picker.
# Navigate with j/k or arrows · Enter to focus · Esc/q to cancel.

$LOAD_PATH.unshift(File.join(__dir__, "..", "lib"))
require "lcctop"
require "ratatui_ruby"
require "json"

include Lcctop

# --- Hyprland helpers -------------------------------------------------------

def hyprland_windows
  JSON.parse(`hyprctl clients -j 2>/dev/null`)
    .each_with_object({}) { |c, h| h[c["pid"].to_i] = c["address"] if c["pid"] }
rescue StandardError
  {}
end

def find_window_for_pid(pid, windows)
  6.times do
    return windows[pid] if windows.key?(pid)
    parent = Session.ppid_of(pid)
    break if parent.nil? || parent <= 1
    pid = parent
  end
  nil
end

# Walk up the process tree to find the PID whose comm matches "ghostty".
def find_ghostty_pid(pid)
  8.times do
    stat = File.read("/proc/#{pid}/stat").split rescue nil
    return nil unless stat
    return pid if stat[1] == "(ghostty)"
    ppid = stat[3].to_i
    return nil if ppid <= 1
    pid = ppid
  end
  nil
end

# Return the 1-based tab index (sorted by process start time) for the tab in
# the given Ghostty instance that contains +session_pid+.  Returns nil when
# the session can't be attributed to a tab (e.g. not running under Ghostty, or
# already on the active tab).
def ghostty_tab_index(session_pid, ghostty_pid)
  # Walk up from session_pid to find its direct-child-of-ghostty ancestor.
  tab_root = nil
  pid = session_pid
  8.times do
    stat = (File.read("/proc/#{pid}/stat").split rescue nil)
    break unless stat
    ppid = stat[3].to_i
    if ppid == ghostty_pid
      tab_root = pid
      break
    end
    break if ppid <= 1
    pid = ppid
  end
  return nil unless tab_root

  # Collect all direct children of ghostty that have a controlling TTY —
  # each represents one tab.  Sort by starttime (field 22, 1-indexed) so the
  # index matches Ghostty's left-to-right tab order.
  tab_roots = []
  Dir["/proc/*/stat"].each do |f|
    parts = (File.read(f).split rescue nil)
    next unless parts
    next unless parts[3].to_i == ghostty_pid
    next if parts[6].to_i == 0 # no controlling TTY → not a tab shell
    tab_roots << [parts[0].to_i, parts[21].to_i]
  end
  tab_roots.sort_by! { |_, starttime| starttime }

  idx = tab_roots.index { |p, _| p == tab_root }
  idx ? idx + 1 : nil
end

# Focus a session: bring its Hyprland window to front, then switch to the
# correct Ghostty tab with wtype Alt+N.
def focus_session(pid, windows)
  address = find_window_for_pid(pid, windows)
  return unless address

  system "hyprctl", "dispatch", "focuswindow", "address:#{address}"

  ghostty_pid = find_ghostty_pid(pid)
  return unless ghostty_pid

  tab_idx = ghostty_tab_index(pid, ghostty_pid)
  return unless tab_idx && tab_idx >= 1 && tab_idx <= 8

  sleep 0.05 # let Hyprland complete the window focus before injecting key
  system "wtype", "-M", "alt", "-k", tab_idx.to_s
end

# --- Color palette ----------------------------------------------------------
# Loaded from ~/.config/omarchy/current/theme/lcctop-pick-colors.json when
# available (auto-regenerated by omarchy-theme-set on every theme switch).
# Falls back to Catppuccin Mocha defaults.

THEME_COLORS_FILE = File.expand_path("~/.config/omarchy/current/theme/lcctop-pick-colors.json")

C = begin
  raw = JSON.parse(File.read(THEME_COLORS_FILE))
  raw.transform_keys(&:to_sym).freeze
rescue
  {
    red:      "#f38ba8",
    amber:    "#f9e2af",
    green:    "#a6e3a1",
    blue:     "#89b4fa",
    purple:   "#cba6f7",
    gray:     "#6c7086",
    subtext:  "#a6adc8",
    overlay1: "#7f849c",
    text:     "#cdd6f4",
    base:     "#1e1e2e",
    mantle:   "#181825",
    surface0: "#313244",
    surface1: "#45475a",
  }.freeze
end

STATUS_COLOR = {
  SessionStatus::WAITING_PERMISSION => C[:red],
  SessionStatus::WAITING_INPUT      => C[:amber],
  SessionStatus::NEEDS_ATTENTION    => C[:amber],
  SessionStatus::WORKING            => C[:green],
  SessionStatus::COMPACTING         => C[:blue],
  SessionStatus::IDLE               => C[:gray],
}.freeze

STATUS_LABEL = {
  SessionStatus::WAITING_PERMISSION => "Permission",
  SessionStatus::WAITING_INPUT      => "Waiting",
  SessionStatus::NEEDS_ATTENTION    => "Attention",
  SessionStatus::WORKING            => "Working",
  SessionStatus::COMPACTING         => "Compacting",
  SessionStatus::IDLE               => "Idle",
}.freeze

R  = RatatuiRuby
S  = R::Style::Style
Sp = R::Text::Span
Ln = R::Text::Line
W  = R::Widgets
Rt = R::Layout::Rect

# --- Card rendering ---------------------------------------------------------

def truncate(str, len)
  s = str.to_s
  s.length > len ? "#{s[0, len - 1]}…" : s
end

def make_line1(session, width, selected)
  status  = session.status
  color   = STATUS_COLOR.fetch(status, C[:gray])
  label   = STATUS_LABEL.fetch(status, "Idle")
  src     = session.source_label
  src_clr = src == "OC" ? C[:blue] : C[:amber]
  name    = truncate(session.display_name, 24)
  time    = session.relative_time
  bg      = selected ? C[:surface0] : nil

  agents_str = session.subagent_count > 0 ? " [#{session.subagent_count}]" : ""

  # Right-align the time: compute padding
  left_plain  = "▍  #{name}#{agents_str}  #{src}  #{label}"
  right_plain = "  #{time}  "
  pad_len     = [width - left_plain.length - right_plain.length - 2, 1].max

  Ln.new(spans: [
    Sp.new(content: "▍", style: S.new(fg: color, bg: bg)),
    Sp.new(content: "  #{name}", style: S.new(fg: C[:text], bg: bg, modifiers: [:bold])),
    Sp.new(content: agents_str, style: S.new(fg: C[:purple], bg: bg)),
    Sp.new(content: "  #{src}", style: S.new(fg: src_clr, bg: bg)),
    Sp.new(content: "  #{label}", style: S.new(fg: color, bg: bg)),
    Sp.new(content: " " * pad_len, style: S.new(bg: bg)),
    Sp.new(content: "#{time}  ", style: S.new(fg: C[:overlay1], bg: bg)),
  ])
end

def make_line2(session, width, selected)
  bg      = selected ? C[:surface0] : nil
  branch  = session.branch || "unknown"
  context = session.context_line

  detail = context ? "#{branch}  /  #{context}" : branch
  detail = truncate(detail, width - 4)

  Ln.new(spans: [
    Sp.new(content: "   #{detail}", style: S.new(fg: C[:subtext], bg: bg)),
    Sp.new(content: " " * [width - detail.length - 3, 0].max, style: S.new(bg: bg)),
  ])
end

def make_separator(width, selected_above, selected_below)
  color = (selected_above || selected_below) ? C[:surface1] : C[:surface0]
  Ln.new(spans: [Sp.new(content: "─" * width, style: S.new(fg: color))])
end

def make_header(sessions, width)
  perm    = sessions.count { |s| s.status == SessionStatus::WAITING_PERMISSION }
  attn    = sessions.count { |s| [SessionStatus::WAITING_INPUT, SessionStatus::NEEDS_ATTENTION].include?(s.status) }
  working = sessions.count { |s| [SessionStatus::WORKING, SessionStatus::COMPACTING].include?(s.status) }
  idle    = sessions.count { |s| s.status == SessionStatus::IDLE }

  dots = []
  dots << Sp.new(content: "● #{perm}  ",  style: S.new(fg: C[:red]))    if perm    > 0
  dots << Sp.new(content: "● #{attn}  ",  style: S.new(fg: C[:amber]))   if attn    > 0
  dots << Sp.new(content: "● #{working}  ", style: S.new(fg: C[:green])) if working > 0
  dots << Sp.new(content: "● #{idle}  ",  style: S.new(fg: C[:gray]))    if idle    > 0

  spans = [
    Sp.new(content: "  lcctop", style: S.new(fg: C[:text], modifiers: [:bold])),
    Sp.new(content: "    ", style: S.new(fg: C[:subtext])),
  ] + dots + [
    Sp.new(content: " " * [width - 10 - dots.sum { |d| d.content.length } - 4, 0].max, style: S.new),
  ]
  Ln.new(spans:)
end

def make_footer(width)
  hints = "  j/↓ next  k/↑ prev  enter focus  q/esc cancel"
  Ln.new(spans: [
    Sp.new(content: truncate(hints, width), style: S.new(fg: C[:gray])),
  ])
end

# --- Session loading --------------------------------------------------------

sessions = WaybarOutput.load_alive_sessions
exit 0 if sessions.empty?

# Auto-focus if only one session
if sessions.size == 1
  focus_session(sessions.first.pid, hyprland_windows)
  exit 0
end

# Pre-select the first session needing attention
selected_idx = sessions.index { |s|
  [SessionStatus::WAITING_PERMISSION, SessionStatus::WAITING_INPUT,
   SessionStatus::NEEDS_ATTENTION].include?(s.status)
} || 0

selected_pid = nil

# --- TUI loop ---------------------------------------------------------------

R.run do |tui|
  loop do
    tui.draw do |frame|
      area = frame.area
      w    = area.width.to_i
      h    = area.height.to_i

      # Outer block (border + title)
      outer = W::Block.new(
        title:        " lcctop ",
        borders:      :all,
        border_style: S.new(fg: C[:surface1]),
        title_style:  S.new(fg: C[:text], modifiers: [:bold]),
      )
      frame.render_widget(outer, Rt.new(x: area.x, y: area.y, width: w, height: h))

      # Inner content area (inside border)
      ix = area.x + 1
      iy = area.y + 1
      iw = w - 2
      ih = h - 2

      # Header row (status dots)
      header_line = make_header(sessions, iw)
      frame.render_widget(
        W::Paragraph.new(text: header_line),
        Rt.new(x: ix, y: iy, width: iw, height: 1)
      )

      # Separator under header
      sep0 = Ln.new(spans: [Sp.new(content: "─" * iw, style: S.new(fg: C[:surface0]))])
      frame.render_widget(
        W::Paragraph.new(text: sep0),
        Rt.new(x: ix, y: iy + 1, width: iw, height: 1)
      )

      # Session cards area: iy+2 .. iy+ih-2 (leave room for header+sep+footer)
      cards_top  = iy + 2
      cards_bot  = iy + ih - 2  # footer at iy+ih-1
      cards_h    = cards_bot - cards_top

      # Card height: 2 lines content + 1 separator = 3 rows
      card_rows  = 3
      visible_n  = cards_h / card_rows

      # Scroll to keep selection visible
      scroll_off = if selected_idx < visible_n
                     0
                   else
                     selected_idx - visible_n + 1
                   end

      sessions.each_with_index do |s, i|
        card_top = cards_top + (i - scroll_off) * card_rows
        next if card_top < cards_top || card_top + card_rows > cards_bot + card_rows

        sel = (i == selected_idx)

        # Line 1: accent + name + source + status + time
        frame.render_widget(
          W::Paragraph.new(text: make_line1(s, iw, sel)),
          Rt.new(x: ix, y: card_top, width: iw, height: 1)
        )

        # Line 2: branch / context
        frame.render_widget(
          W::Paragraph.new(text: make_line2(s, iw, sel)),
          Rt.new(x: ix, y: card_top + 1, width: iw, height: 1)
        )

        # Separator (skip after last session)
        next if i == sessions.size - 1
        sel_below = (i + 1 == selected_idx)
        frame.render_widget(
          W::Paragraph.new(text: make_separator(iw, sel, sel_below)),
          Rt.new(x: ix, y: card_top + 2, width: iw, height: 1)
        )
      end

      # Footer: keyboard hints
      frame.render_widget(
        W::Paragraph.new(text: make_footer(iw)),
        Rt.new(x: ix, y: iy + ih - 1, width: iw, height: 1)
      )
    end

    event = tui.poll_event(timeout: nil)
    next unless event.key?

    case
    when event.key_down? || event == "j"
      selected_idx = [selected_idx + 1, sessions.size - 1].min
    when event.key_up? || event == "k"
      selected_idx = [selected_idx - 1, 0].max
    when event.enter?
      selected_pid = sessions[selected_idx]&.pid
      break
    when event.esc? || event == "q" || event.ctrl_c?
      break
    end
  end
end

focus_session(selected_pid, hyprland_windows) if selected_pid && selected_pid > 0
