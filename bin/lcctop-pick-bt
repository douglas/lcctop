#!/usr/bin/env ruby
# frozen_string_literal: true
# lcctop-pick-bt: Session picker using bubbletea + lipgloss (Elm architecture).
# Parallel implementation to lcctop-pick (ratatui_ruby) — same UI, different framework.
# Navigate with j/k or arrows · Enter to focus · Esc/q to cancel.

$LOAD_PATH.unshift(File.join(__dir__, "..", "lib"))
require "lcctop"
require "bubbletea"
require "lipgloss"
require "json"

include Lcctop

# --- Hyprland helpers -------------------------------------------------------

def hyprland_windows
  JSON.parse(`hyprctl clients -j 2>/dev/null`)
    .each_with_object({}) { |c, h| h[c["pid"].to_i] = c["address"] if c["pid"] }
rescue StandardError
  {}
end

def find_window_for_pid(pid, windows)
  6.times do
    return windows[pid] if windows.key?(pid)
    parent = Session.ppid_of(pid)
    break if parent.nil? || parent <= 1
    pid = parent
  end
  nil
end

def detect_terminal(pid)
  8.times do
    stat = (File.read("/proc/#{pid}/stat").split rescue nil)
    return nil unless stat
    type = case stat[1]
           when "(ghostty)"   then :ghostty
           when "(kitty)"     then :kitty
           when "(alacritty)" then :alacritty
           end
    return { type: type, pid: pid } if type
    ppid = stat[3].to_i
    return nil if ppid <= 1
    pid = ppid
  end
  nil
end

def find_tab_root(session_pid, terminal_pid)
  pid = session_pid
  8.times do
    stat = (File.read("/proc/#{pid}/stat").split rescue nil)
    break unless stat
    ppid = stat[3].to_i
    return pid if ppid == terminal_pid
    break if ppid <= 1
    pid = ppid
  end
  nil
end

def ghostty_switch_tab(tab_root, ghostty_pid)
  tab_roots = []
  Dir["/proc/*/stat"].each do |f|
    parts = (File.read(f).split rescue nil)
    next unless parts
    next unless parts[3].to_i == ghostty_pid
    next if parts[6].to_i == 0
    tab_roots << [parts[0].to_i, parts[21].to_i]
  end
  tab_roots.sort_by! { |_, starttime| starttime }
  idx = tab_roots.index { |p, _| p == tab_root }
  return unless idx
  tab_idx = idx + 1
  return unless tab_idx >= 1 && tab_idx <= 8
  system "wtype", "-M", "alt", "-k", tab_idx.to_s
end

def kitty_switch_tab(tab_root)
  ls = JSON.parse(`kitty @ ls 2>/dev/null`) rescue return
  ls.each do |os_window|
    os_window["tabs"].each do |tab|
      tab["windows"].each do |window|
        if window["pid"] == tab_root
          system "kitty", "@", "focus-tab", "--match", "id:#{tab["id"]}"
          return
        end
      end
    end
  end
end

def focus_session(pid, windows)
  address = find_window_for_pid(pid, windows)
  return unless address
  system "hyprctl", "dispatch", "focuswindow", "address:#{address}"
  terminal = detect_terminal(pid)
  return unless terminal
  tab_root = find_tab_root(pid, terminal[:pid])
  return unless tab_root
  sleep 0.05
  case terminal[:type]
  when :ghostty   then ghostty_switch_tab(tab_root, terminal[:pid])
  when :kitty     then kitty_switch_tab(tab_root)
  when :alacritty then nil
  end
end

# --- Color palette ----------------------------------------------------------

THEME_COLORS_FILE = File.expand_path("~/.config/omarchy/current/theme/lcctop-pick-colors.json")

C = begin
  raw = JSON.parse(File.read(THEME_COLORS_FILE))
  raw.transform_keys(&:to_sym).freeze
rescue
  {
    red:      "#f38ba8",
    amber:    "#f9e2af",
    green:    "#a6e3a1",
    blue:     "#89b4fa",
    purple:   "#cba6f7",
    gray:     "#6c7086",
    subtext:  "#a6adc8",
    overlay1: "#7f849c",
    text:     "#cdd6f4",
    base:     "#1e1e2e",
    mantle:   "#181825",
    surface0: "#313244",
    surface1: "#45475a",
  }.freeze
end

STATUS_COLOR = {
  SessionStatus::WAITING_PERMISSION => C[:red],
  SessionStatus::WAITING_INPUT      => C[:amber],
  SessionStatus::NEEDS_ATTENTION    => C[:amber],
  SessionStatus::WORKING            => C[:green],
  SessionStatus::COMPACTING         => C[:blue],
  SessionStatus::IDLE               => C[:gray],
}.freeze

STATUS_LABEL = {
  SessionStatus::WAITING_PERMISSION => "Permission",
  SessionStatus::WAITING_INPUT      => "Waiting",
  SessionStatus::NEEDS_ATTENTION    => "Attention",
  SessionStatus::WORKING            => "Working",
  SessionStatus::COMPACTING         => "Compacting",
  SessionStatus::IDLE               => "Idle",
}.freeze

# --- Helpers ----------------------------------------------------------------

def truncate(str, len)
  s = str.to_s
  s.length > len ? "#{s[0, len - 1]}…" : s
end

# Build a Lipgloss::Style with common options.
def lsty(fg: nil, bg: nil, bold: false)
  s = Lipgloss::Style.new
  s = s.foreground(fg) if fg
  s = s.background(bg) if bg
  s = s.bold(true) if bold
  s
end

# --- Card rendering ---------------------------------------------------------

def bt_line1(session, selected, width)
  bg      = selected ? C[:surface0] : nil
  status  = session.status
  color   = STATUS_COLOR.fetch(status, C[:gray])
  label   = STATUS_LABEL.fetch(status, "Idle")
  src     = session.source_label
  src_clr = src == "OC" ? C[:blue] : C[:amber]
  name    = truncate(session.display_name, 24)
  time    = session.relative_time
  agents  = session.subagent_count > 0 ? " [#{session.subagent_count}]" : ""

  left_plain  = "▍  #{name}#{agents}  #{src}  #{label}"
  right_plain = "#{time}  "
  pad_len     = [width - left_plain.length - right_plain.length, 1].max

  lsty(fg: color, bg: bg).render("▍") +
    lsty(fg: C[:text], bg: bg, bold: true).render("  #{name}") +
    lsty(fg: C[:purple], bg: bg).render(agents) +
    lsty(fg: src_clr, bg: bg).render("  #{src}") +
    lsty(fg: color, bg: bg).render("  #{label}") +
    lsty(bg: bg).render(" " * pad_len) +
    lsty(fg: C[:overlay1], bg: bg).render("#{time}  ")
end

def bt_line2(session, selected, width)
  bg     = selected ? C[:surface0] : nil
  branch = session.branch || "unknown"
  ctx    = session.context_line
  detail = ctx ? "#{branch}  /  #{ctx}" : branch
  detail = truncate(detail, width - 4)
  pad_len = [width - detail.length - 3, 0].max

  lsty(fg: C[:subtext], bg: bg).render("   #{detail}") +
    lsty(bg: bg).render(" " * pad_len)
end

def bt_header(sessions, _width)
  perm    = sessions.count { |s| s.status == SessionStatus::WAITING_PERMISSION }
  attn    = sessions.count { |s| [SessionStatus::WAITING_INPUT, SessionStatus::NEEDS_ATTENTION].include?(s.status) }
  working = sessions.count { |s| [SessionStatus::WORKING, SessionStatus::COMPACTING].include?(s.status) }
  idle    = sessions.count { |s| s.status == SessionStatus::IDLE }

  dots = ""
  dots += lsty(fg: C[:red]).render("● #{perm}  ")     if perm    > 0
  dots += lsty(fg: C[:amber]).render("● #{attn}  ")   if attn    > 0
  dots += lsty(fg: C[:green]).render("● #{working}  ") if working > 0
  dots += lsty(fg: C[:gray]).render("● #{idle}  ")    if idle    > 0

  lsty(fg: C[:text], bold: true).render("  lcctop") +
    lsty(fg: C[:subtext]).render("    ") +
    dots
end

def bt_footer(width)
  hints = "  j/↓ next  k/↑ prev  enter focus  q/esc cancel"
  lsty(fg: C[:gray]).render(truncate(hints, width))
end

# --- Bubbletea Model (Elm architecture) -------------------------------------

class PickModel
  include Bubbletea::Model

  def initialize(sessions, windows)
    @sessions     = sessions
    @windows      = windows
    @selected_idx = sessions.index { |s|
      [SessionStatus::WAITING_PERMISSION, SessionStatus::WAITING_INPUT,
       SessionStatus::NEEDS_ATTENTION].include?(s.status)
    } || 0
    @selected_pid = nil
    @width  = 80
    @height = 24
  end

  attr_reader :selected_pid

  def init = [self, nil]

  def update(msg)
    case msg
    when Bubbletea::WindowSizeMessage
      @width  = msg.width
      @height = msg.height
    when Bubbletea::KeyMessage
      case msg.to_s
      when "down", "j" then @selected_idx = [@selected_idx + 1, @sessions.size - 1].min
      when "up",   "k" then @selected_idx = [@selected_idx - 1, 0].max
      when "enter"
        @selected_pid = @sessions[@selected_idx]&.pid
        return [self, Bubbletea.quit]
      when "esc", "q", "ctrl+c"
        return [self, Bubbletea.quit]
      end
    end
    [self, nil]
  end

  def view
    w       = @width
    inner_w = w - 2  # rounded border takes 1 char each side

    header_str = bt_header(@sessions, inner_w)
    sep_str    = lsty(fg: C[:surface0]).render("─" * inner_w)

    # Scrolling: card_rows = 2 content lines + 1 separator
    card_rows = 3
    cards_h   = [@height - 6, card_rows].max
    visible_n = cards_h / card_rows

    scroll_off       = @selected_idx < visible_n ? 0 : @selected_idx - visible_n + 1
    visible_sessions = @sessions[scroll_off, visible_n] || []

    card_lines = []
    visible_sessions.each_with_index do |s, local_i|
      global_i = local_i + scroll_off
      sel      = (global_i == @selected_idx)
      card_lines << bt_line1(s, sel, inner_w)
      card_lines << bt_line2(s, sel, inner_w)
      next if global_i == @sessions.size - 1
      next_sel  = (global_i + 1 == @selected_idx)
      sep_color = (sel || next_sel) ? C[:surface1] : C[:surface0]
      card_lines << lsty(fg: sep_color).render("─" * inner_w)
    end

    footer_str = bt_footer(inner_w)

    content = Lipgloss.join_vertical(:left,
      header_str, sep_str, *card_lines, footer_str)

    Lipgloss::Style.new
      .border(:rounded)
      .border_foreground(C[:surface1])
      .width(inner_w)
      .render(content)
  end
end

# --- Main -------------------------------------------------------------------

sessions = WaybarOutput.load_alive_sessions
exit 0 if sessions.empty?

windows = hyprland_windows
model   = PickModel.new(sessions, windows)
Bubbletea.run(model, alt_screen: true)

focus_session(model.selected_pid, windows) if model.selected_pid && model.selected_pid > 0
