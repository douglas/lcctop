/* lcctop waybar status colors — auto-generated from theme's colors.toml */
/* Processed by omarchy-theme-set-templates on every theme switch.        */
/* Output: ~/.config/omarchy/current/theme/lcctop-waybar.css              */

@define-color lcctop-disconnected {{ color1 }};   /* red   — no active sessions    */
@define-color lcctop-permission   {{ color1 }};   /* red   — needs permission      */
@define-color lcctop-attention    {{ color3 }};   /* amber — needs attention       */
@define-color lcctop-working      {{ color2 }};   /* green — actively working      */
@define-color lcctop-idle         {{ color8 }};   /* gray  — idle                  */
@define-color lcctop-compacting   {{ color4 }};   /* blue  — compacting context    */
