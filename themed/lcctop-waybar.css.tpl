/* lcctop waybar status colors — auto-generated from theme's colors.toml */
/* Processed by omarchy-theme-set-templates on every theme switch.        */
/* Output: ~/.config/omarchy/current/theme/lcctop-waybar.css              */

@define-color lcctop-disconnected {{ color1 }};   /* red  — no active sessions */
@define-color lcctop-connected    {{ color4 }};   /* blue — sessions active    */
